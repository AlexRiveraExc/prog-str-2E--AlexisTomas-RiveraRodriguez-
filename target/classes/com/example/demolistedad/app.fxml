<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>


<Pane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demolistedad.controllers.AppController">
   <children>
      <VBox spacing="10">
      
             <HBox spacing="10" />
         <Pane>
            <children>
            
                   <ListView fx:id="listView" prefHeight="200" />
           <TextField fx:id="nombreField" layoutX="280.0" layoutY="16.0" promptText="Nombre" />
           <TextField fx:id="correoField" layoutX="280.0" layoutY="57.0" promptText="Correo" />
           <TextField fx:id="edadField" layoutX="280.0" layoutY="100.0" promptText="Edad" />
           <Button alignment="TOP_RIGHT" layoutX="318.0" layoutY="144.0" onAction="#guardarPersona" prefHeight="25.0" prefWidth="59.0" text="Guardar" />
            </children>
         </Pane>
      
                   <Label fx:id="detalleLabel" text="Selecciona una persona" />
      </VBox>
   </children>
</Pane>
