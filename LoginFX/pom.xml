<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.loginfx.LoginController">

    <Label text="LOGIN" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TextField fx:id="txtCorreo" promptText="Correo"/>
    <PasswordField fx:id="txtPassword" promptText="Contraseña"/>

    <Label fx:id="lblError" textFill="red"/>

    <Button text="Ingresar" onAction="#login"/>

</VBox>